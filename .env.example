# =============================================================================
# PHOENIX CHESS ACADEMY — ENVIRONMENT VARIABLES
# =============================================================================
# Copy this file to .env.local for local development. Never commit real
# secrets. Production values are configured in the hosting provider
# (Vercel) environment settings, not in this repository.

# -----------------------------------------------------------------------
# SITE
# -----------------------------------------------------------------------
# Canonical production URL. Local development may override this with
# http://localhost:3000, but production SEO/sitemap/robots/OG/structured
# data must resolve to https://phoenixchessacademy.org.
NEXT_PUBLIC_SITE_URL=https://phoenixchessacademy.org

# -----------------------------------------------------------------------
# SUPABASE (Phase 7 — database foundation)
# -----------------------------------------------------------------------
# Public URL + anon key. Safe to expose to the browser — the anon key is
# meaningless without RLS policies granting it something, and Phase 7's
# sensitive tables (contact_enquiries, trial_bookings,
# tournament_registrations, reporting_outbox, profiles) grant it nothing.
# See docs/DATABASE_ARCHITECTURE.md, "RLS Strategy".
NEXT_PUBLIC_SUPABASE_URL=https://veqyyfeolxuynqjqitsz.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InZlcXl5ZmVvbHh1eW5xanFpdHN6Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODM0OTI0NDIsImV4cCI6MjA5OTA2ODQ0Mn0.TKHm2sIxNTQqMLXzoi3Hj4H2IE0W4iSQBsn71yJFptE
# Server-only. NEVER prefix with NEXT_PUBLIC_, never import into a Client
# Component (src/lib/supabase/admin.ts enforces this with `server-only`).
# Bypasses Row Level Security entirely. Used only by the internal
# reporting-outbox sync worker in Phase 7 — see
# docs/GOOGLE_SHEETS_REPORTING.md.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InZlcXl5ZmVvbHh1eW5xanFpdHN6Iiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc4MzQ5MjQ0MiwiZXhwIjoyMDk5MDY4NDQyfQ.s4brfghVE7dzXrUmKgKDtL_CZVFFFJoKikWghhBK2sI


# -----------------------------------------------------------------------
# GOOGLE SHEETS REPORTING (Phase 7 — optional; see docs/GOOGLE_SHEETS_REPORTING.md)
# -----------------------------------------------------------------------
# Service-account email, e.g. phoenix-reporting@my-project.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_EMAIL=
# Server-only. Never expose to the client. The private key from the
# downloaded service-account JSON contains literal "\n" sequences — when
# pasting into a .env file, KEEP them as the two-character escape "\n"
# (do not convert to real newlines), wrap the whole value in double
# quotes, and this codebase converts "\n" -> real newlines at runtime
# (see src/lib/google/sheets.ts, `normalizePrivateKey()`). Example shape:
# GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEva...\n-----END PRIVATE KEY-----\n"
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=
# The spreadsheet's ID from its URL
# (https://docs.google.com/spreadsheets/d/<THIS_PART>/edit). Not a
# secret on the level of a private key, but still not rendered in any
# public UI — see docs/GOOGLE_SHEETS_REPORTING.md, "Privacy".
GOOGLE_SHEETS_SPREADSHEET_ID=
# Shared secret required by /api/internal/reporting/sync — without it,
# the route returns 401. Generate a long random value, e.g.
# `openssl rand -hex 32`. Required only if triggering the sync worker via
# an external cron (Vercel Cron, GitHub Actions, etc.).
CRON_SECRET=

# -----------------------------------------------------------------------
# CLOUDFLARE R2 (configured in Phase 13)
# -----------------------------------------------------------------------
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET_NAME=
# Public read domain for R2 media (custom domain configured later, e.g.
# https://media.phoenixchessacademy.org).
CLOUDFLARE_R2_PUBLIC_URL=

# -----------------------------------------------------------------------
# ANALYTICS (configured in Phase 15)
# -----------------------------------------------------------------------
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_GTM_ID=
NEXT_PUBLIC_CLARITY_ID=
