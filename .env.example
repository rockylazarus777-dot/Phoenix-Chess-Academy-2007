# Phoenix Chess Academy — environment variables
#
# Copy this file to .env.local (already git-ignored — see .gitignore) and
# fill in real values there. Never commit real secrets to this file or
# any other tracked file.
#
# NOTE ON EMAIL / SMTP: there are deliberately no SMTP/App-Password
# variables in this file. Supabase Auth's email sending (invite, password
# reset) is a Supabase *project-level* setting configured entirely in the
# Supabase Dashboard (Authentication -> Emails -> SMTP Settings) — this
# Next.js app never sends email itself and has no SMTP client. See
# docs/EMAIL_SMTP_CONFIGURATION.md for the exact values to enter there.

# -----------------------------------------------------------------------
# Supabase (required — auth, database, portals)
# -----------------------------------------------------------------------
# Project URL and anon key: Supabase Dashboard -> Project Settings -> API.
# Public/browser-safe by design.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service-role key: same Dashboard page. SERVER-ONLY — bypasses Row Level
# Security entirely. Never expose to the browser, never prefix with
# NEXT_PUBLIC_. Used only by src/lib/supabase/admin.ts (invite/provision
# admin actions, the internal reporting sync worker).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# -----------------------------------------------------------------------
# Site URL (required in production)
# -----------------------------------------------------------------------
# The canonical production origin — used to build every Supabase
# redirectTo (invite/reset emails -> /auth/callback), every SEO
# canonical/sitemap/structured-data URL, and Open Graph tags. Falls back
# to the hardcoded constant in src/config/site.ts if unset, but that
# fallback exists only as a safety net — always set this explicitly in
# every deployed environment so a misconfigured env can never silently
# send auth emails to the wrong host.
#
# Production value must exactly match a URL in Supabase's Redirect URLs
# allow-list (Authentication -> URL Configuration).
NEXT_PUBLIC_SITE_URL=https://www.phoenixchessacademy.org

# Local development value (uncomment when running `next dev`; also add
# http://localhost:3000/auth/callback to Supabase's Redirect URLs
# allow-list for local testing):
# NEXT_PUBLIC_SITE_URL=http://localhost:3000

# -----------------------------------------------------------------------
# Cron / internal reporting sync (required for the reporting worker)
# -----------------------------------------------------------------------
# Shared secret checked by src/app/api/internal/reporting/sync/route.ts.
# Generate a long random value; do not reuse any other secret.
CRON_SECRET=your-cron-secret

# -----------------------------------------------------------------------
# Cloudflare R2 (required for certificate PDF storage/download)
# -----------------------------------------------------------------------
CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id
CLOUDFLARE_R2_ACCESS_KEY_ID=your-r2-access-key-id
CLOUDFLARE_R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
CLOUDFLARE_R2_CERTIFICATES_BUCKET=your-r2-bucket-name

# -----------------------------------------------------------------------
# Google Sheets reporting export (required for the reporting worker)
# -----------------------------------------------------------------------
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
# Multi-line PEM key — keep the literal \n escapes if your hosting
# platform requires a single-line env value.
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY\n-----END PRIVATE KEY-----\n"
GOOGLE_SHEETS_SPREADSHEET_ID=your-spreadsheet-id

# -----------------------------------------------------------------------
# Analytics (optional — safe to leave unset)
# -----------------------------------------------------------------------
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_GTM_ID=
NEXT_PUBLIC_CLARITY_ID=
